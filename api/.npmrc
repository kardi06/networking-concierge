# Use a flat node_modules layout (like npm/yarn) instead of pnpm's default
# symlinked .pnpm structure. This is required for Prisma 7's CLI to find
# @prisma/engines and other transitive deps reliably — pnpm's strict isolation
# breaks `pnpm exec prisma generate` inside the Docker build with errors like
# "Cannot find module '@prisma/engines'" or "/app/node_modules/prisma/build/index.js".
#
# Trade-off: we lose pnpm's strict isolation benefit. Acceptable for this
# project; documented in TD-007.
node-linker=hoisted
