# =============================================================================
# MyConnect Networking Concierge — environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# --- Database ---
# Local docker-compose Postgres on host port 5433 (5432 reserved for native Postgres).
# Inside docker-compose, services on the same network reach it as `postgres:5432`.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/myconnect?schema=public"

# --- LLM providers ---
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""
# Default agent model. claude-sonnet-4-6 has stable native tool calling.
ANTHROPIC_MODEL="claude-sonnet-4-6"

# Get from https://platform.openai.com/api-keys
# Used only for text-embedding-3-small (1536 dim).
OPENAI_API_KEY=""

# --- Score service (FastAPI microservice) ---
# Local default; in docker-compose this becomes http://score-service:8000
SCORE_SERVICE_URL="http://localhost:8000"

# --- NestJS app ---
PORT=3000
NODE_ENV="development"
LOG_LEVEL="info"

# --- Rate limiting (per attendee per minute) ---
RATE_LIMIT_PER_MIN=10
